		{
			"src": "^/loan-programs/?$",
			"dest": "_render"
		},
		{
			"src": "^/wide-equity-select-short-landing-page/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}