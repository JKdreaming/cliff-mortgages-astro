{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/cindy-cliff/?$",
			"dest": "_render"
		},
		{
			"src": "^/about/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/submit-heloc-form/?$",
			"dest": "_render"
		},
		{
			"src": "^/components-we-use/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/equity-select-short-landing/?$",
			"dest": "_render"
		},
		{
			"src": "^/equityselect-landing/?$",
			"dest": "_render"
		},
		{
			"src": "^/get-a-quote/?$",
			"dest": "_render"
		},
		{
			"src": "^/heloc-access-landing/?$",
			"dest": "_render"
		},
		{
			"src": "^/legal/accessibility/?$",
			"dest": "_render"
